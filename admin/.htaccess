# Interdire l'accès direct aux fichiers sensibles
<FilesMatch "\.(json|html)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Autoriser seulement admin.php et generate-password.php
<Files "admin.php">
  Allow from all
</Files>

<Files "generate-password.php">
  Allow from all
</Files>

# Protéger le dossier uploads
RewriteEngine On
RewriteRule ^uploads/ - [F]