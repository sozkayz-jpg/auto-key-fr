RewriteEngine On

# Redirection permanente ancien domaine
RewriteCond %{HTTP_HOST} ^auto-key\.fr [NC]
RewriteRule ^(.*)$ https://www.allo-cle-auto.fr/$1 [L,R=301]

# HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

# Retirer .html des URLs existantes
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [L,R=301]

# Reecriture simple : page.html -> page (root level only)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# API : pas de rewrite
RewriteRule ^api/ - [L]

ErrorDocument 404 /404.html

Options -Indexes
ServerSignature Off
